{ // in this file it will override the settings in appsettings.json, appsettings.Development.json and even launchSettings.Json
    // for example here we are setting the logging level to "Trace" for the development environment
    // so the default loglevel configuration will be returned as "Trace" instead of "Information"
    "Logging": {
        "LogLevel": {
            "Default": "Trace" 
        }
    },
    "TestKey": "TestValue"
}