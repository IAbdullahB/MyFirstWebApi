{ // in this file it will override the settings in appsettings.json when running in development environment
    // for example here we are setting the logging level to "Debug" for the development environment
    // so the default loglevel configuration will be returned as "Debug" instead of "Information" 
    "Logging": {
        "LogLevel": {
            "Default": "Debug",
            "Microsoft.AspNetCore": "Warning"
        }
    }
}

// In ASP.NET Core, logging levels are hierarchical. They range from least severe to most severe 
// (e.g., Trace -> Debug -> Information -> Warning -> Error -> Critical).
// When I set a log level, I am telling the application, "Only show me messages of this severity level or higher."
